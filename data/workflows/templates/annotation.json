{
  "name": "Genome Annotation Pipeline",
  "description": "Comprehensive genome annotation workflow for viral genomes. Performs gene prediction, functional annotation, and comparative analysis.",
  "nodes": [
    {
      "node_id": "prodigal_1",
      "tool_id": 16,
      "name": "Prokka Gene Prediction",
      "config": {
        "mode": "meta",
        "organism": "virus",
        "genetic_code": 11,
        "threads": 4
      },
      "x": 50,
      "y": 150,
      "inputs": [],
      "outputs": ["gene_predictions_gff", "predicted_proteins_faa"]
    },
    {
      "node_id": "prodigal_2",
      "tool_id": 16,
      "name": "Prodigal Gene Prediction",
      "config": {
        "mode": "meta",
        "output_format": "fasta",
        "threads": 4
      },
      "x": 50,
      "y": 280,
      "inputs": [],
      "outputs": ["predicted_proteins_faa"]
    },
    {
      "node_id": "blastp_1",
      "tool_id": 11,
      "name": "BLASTp Search",
      "config": {
        "database": "nr",
        "evalue": 1e-5,
        "max_target_seqs": 5,
        "outfmt": "6",
        "threads": 8
      },
      "x": 250,
      "y": 150,
      "inputs": ["predicted_proteins_faa"],
      "outputs": ["blastp_results"]
    },
    {
      "node_id": "hmmer_1",
      "tool_id": 12,
      "name": "HMMER Search",
      "config": {
        "database": "pfam",
        "evalue": 1e-3,
        "cpu": 8
      },
      "x": 250,
      "y": 280,
      "inputs": ["predicted_proteins_faa"],
      "outputs": ["hmmer_results"]
    },
    {
      "node_id": "interproscan_1",
      "tool_id": 17,
      "name": "InterProScan",
      "config": {
        "datadir": "/path/to/interproscan",
        "processors": 8,
        "goterms": true,
        "iprlookup": true
      },
      "x": 450,
      "y": 200,
      "inputs": ["predicted_proteins_faa"],
      "outputs": ["interpro_results"]
    },
    {
      "node_id": "signalp_1",
      "tool_id": 18,
      "name": "SignalP",
      "config": {
        "organism": "eukaryote",
        "format": "short",
        "cpu": 4
      },
      "x": 250,
      "y": 400,
      "inputs": ["predicted_proteins_faa"],
      "outputs": ["signalp_results"]
    },
    {
      "node_id": "tmhmm_1",
      "tool_id": 19,
      "name": "TMHMM",
      "config": {
        "format": "short"
      },
      "x": 250,
      "y": 520,
      "inputs": ["predicted_proteins_faa"],
      "outputs": ["tmhmm_results"]
    },
    {
      "node_id": "annotation_aggregator_1",
      "tool_id": 20,
      "name": "Annotation Aggregator",
      "config": {
        "merge_strategy": "consensus",
        "min_evalue": 1e-10
      },
      "x": 650,
      "y": 200,
      "inputs": ["blastp_results", "hmmer_results", "interpro_results"],
      "outputs": ["combined_annotations"]
    },
    {
      "node_id": "gff3_validator_1",
      "tool_id": 21,
      "name": "GFF3 Validation",
      "config": {
        "strict_mode": true,
        "check_references": true
      },
      "x": 450,
      "y": 80,
      "inputs": ["gene_predictions_gff"],
      "outputs": ["validated_gff3"]
    },
    {
      "node_id": "annotation_report_1",
      "tool_id": 22,
      "name": "Annotation Report",
      "config": {
        "format": "html",
        "include_plots": true
      },
      "x": 850,
      "y": 200,
      "inputs": ["combined_annotations", "validated_gff3"],
      "outputs": ["annotation_report_html"]
    }
  ],
  "connections": [
    {
      "connection_id": "conn_1",
      "source_node_id": "prodigal_1",
      "source_output": "predicted_proteins_faa",
      "target_node_id": "blastp_1",
      "target_input": "predicted_proteins_faa"
    },
    {
      "connection_id": "conn_2",
      "source_node_id": "prodigal_1",
      "source_output": "predicted_proteins_faa",
      "target_node_id": "hmmer_1",
      "target_input": "predicted_proteins_faa"
    },
    {
      "connection_id": "conn_3",
      "source_node_id": "prodigal_1",
      "source_output": "predicted_proteins_faa",
      "target_node_id": "interproscan_1",
      "target_input": "predicted_proteins_faa"
    },
    {
      "connection_id": "conn_4",
      "source_node_id": "prodigal_1",
      "source_output": "predicted_proteins_faa",
      "target_node_id": "signalp_1",
      "target_input": "predicted_proteins_faa"
    },
    {
      "connection_id": "conn_5",
      "source_node_id": "prodigal_1",
      "source_output": "predicted_proteins_faa",
      "target_node_id": "tmhmm_1",
      "target_input": "predicted_proteins_faa"
    },
    {
      "connection_id": "conn_6",
      "source_node_id": "blastp_1",
      "source_output": "blastp_results",
      "target_node_id": "annotation_aggregator_1",
      "target_input": "blastp_results"
    },
    {
      "connection_id": "conn_7",
      "source_node_id": "hmmer_1",
      "source_output": "hmmer_results",
      "target_node_id": "annotation_aggregator_1",
      "target_input": "hmmer_results"
    },
    {
      "connection_id": "conn_8",
      "source_node_id": "interproscan_1",
      "source_output": "interpro_results",
      "target_node_id": "annotation_aggregator_1",
      "target_input": "interpro_results"
    },
    {
      "connection_id": "conn_9",
      "source_node_id": "annotation_aggregator_1",
      "source_output": "combined_annotations",
      "target_node_id": "annotation_report_1",
      "target_input": "combined_annotations"
    },
    {
      "connection_id": "conn_10",
      "source_node_id": "gff3_validator_1",
      "source_output": "validated_gff3",
      "target_node_id": "annotation_report_1",
      "target_input": "validated_gff3"
    }
  ],
  "metadata": {
    "category": "Annotation",
    "complexity": "advanced",
    "estimated_runtime": "1-3 hours",
    "input_requirements": ["genome_fasta"],
    "output_formats": ["gff3", "html", "tsv"]
  }
}
